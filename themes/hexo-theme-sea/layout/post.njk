<article class="sea-page-card-wrapper">
  <header class="sea-article-header">
    <h1 class="sea-article-title">{{ page.title }}</h1>
    {% if is_post() %}
      <div class="sea-post-meta sea-post-meta__center">
        {{ partial('_partial/post/post_date', {post_date: page.date}) }}
        {{ partial('_partial/post/post_categories', {post_categories: page.categories}) }}
        {{ partial('_partial/post/post_tags', {post_tags: page.tags}) }}
        {% if theme.counter.enable and theme.counter.type %}
          {% set counterIdPrefix = 'vercount_value' if theme.counter.type === 'vercount' else 'busuanzi_value' %}
          <span class="sea-post-counter">{{ partial('svg/eye') }} {{ _p('footer.page_pv') }} <span id="{{ counterIdPrefix }}_page_pv">0</span></span>
        {% endif %}
      </div>
    {% endif %}
  </header>
  {% set tocContent = toc(page.content) %}
  <div class="sea-doc{% if theme.toc.enable and tocContent %} sea-doc-with-toc{% endif %}">
    {% if page.toc and tocContent %}
      <div class="sea-article-catalog">
        <h2 class="sea-article-catalog-title">
          {{ partial('svg/arrow_right_fill') }}
          {{ __('page.contents') }}
        </h2>
        {{ tocContent }}
      </div>
    {% endif %}
    <div class="sea-article-content">
      {{ render(page.content) }}
    </div>
    {% if theme.toc.enable and tocContent %}
      <aside class="sea-article-toc-sidebar">
        <div class="sea-article-toc-sidebar-inner">
          <h3 class="sea-article-toc-title">{{ __('page.contents') }}</h3>
          {{ tocContent }}
        </div>
      </aside>
    {% endif %}
  </div>

  {% if is_post() %}
    {{ partial('_partial/main/prev_next') }}
  {% endif %}
</article>

{{ partial('_plugins/comments/index') }}

<script defer>
  document.addEventListener('DOMContentLoaded', function () {
    const toggleIcon = document.querySelector('.sea-article-catalog-title .sea-svg-icon');
    const tocContent = document.querySelector('.sea-article-catalog > .toc');
    if (toggleIcon && tocContent) {
      toggleIcon.addEventListener('click', function () {
        tocContent.classList.toggle('sea-article-catalog-show');
        toggleIcon.classList.toggle('sea-svg-icon-rotate');
      });
    }

    // 右侧目录滚动高亮
    const tocSidebar = document.querySelector('.sea-article-toc-sidebar');
    if (tocSidebar) {
      const tocLinks = tocSidebar.querySelectorAll('.toc-link');
      const headings = document.querySelectorAll('.sea-doc h1, .sea-doc h2, .sea-doc h3, .sea-doc h4, .sea-doc h5, .sea-doc h6');

      if (tocLinks.length > 0 && headings.length > 0) {
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              const id = entry.target.getAttribute('id');
              tocLinks.forEach(link => {
                link.classList.remove('is-active');
                // 解码 href 后再比较
                const linkHref = decodeURIComponent(link.getAttribute('href'));
                if (linkHref === '#' + id) {
                  link.classList.add('is-active');
                }
              });
            }
          });
        }, { rootMargin: '-80px 0px -80% 0px' });

        headings.forEach(heading => {
          if (heading.id) observer.observe(heading);
        });

        // 点击目录平滑滚动
        tocLinks.forEach(link => {
          link.addEventListener('click', function (e) {
            e.preventDefault();
            // 解码 href 获取目标 id
            const targetId = decodeURIComponent(this.getAttribute('href')).substring(1);
            const targetElement = document.getElementById(targetId);
            if (targetElement) {
              const headerOffset = 80;
              const elementPosition = targetElement.getBoundingClientRect().top;
              const offsetPosition = elementPosition + window.pageYOffset - headerOffset;
              window.scrollTo({ top: offsetPosition, behavior: 'smooth' });
            }
          });
        });
      }
    }
  });
</script>